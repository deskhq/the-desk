{
	"$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
	"name": "crontab",
	"scopeName": "source.crontab",
	"aliases": ["cron"],
	"patterns": [
		{ "include": "#comment" },
		{ "include": "#environment" },
		{ "include": "#nickname-schedule" },
		{ "include": "#field-schedule" }
	],
	"repository": {
		"comment": {
			"match": "^\\s*#.*$",
			"name": "comment.line.number-sign.crontab"
		},
		"environment": {
			"match": "^\\s*([A-Za-z_][A-Za-z0-9_]*)\\s*(=)",
			"captures": {
				"1": { "name": "variable.other.environment.crontab" },
				"2": { "name": "keyword.operator.assignment.crontab" }
			}
		},
		"nickname-schedule": {
			"match": "^\\s*(@(?:annually|yearly|monthly|weekly|daily|midnight|hourly|reboot))\\b",
			"captures": {
				"1": { "name": "keyword.other.special-schedule.crontab" }
			}
		},
		"field-schedule": {
			"match": "^\\s*([-0-9*,/]+)\\s+([-0-9*,/]+)\\s+([-0-9*,/]+)\\s+([-0-9*,/A-Za-z]+)\\s+([-0-9*,/A-Za-z]+)(?=\\s)",
			"captures": {
				"1": { "name": "constant.numeric.minute.crontab" },
				"2": { "name": "constant.numeric.hour.crontab" },
				"3": { "name": "constant.numeric.day-of-month.crontab" },
				"4": { "name": "constant.numeric.month.crontab" },
				"5": { "name": "constant.numeric.day-of-week.crontab" }
			}
		}
	}
}
